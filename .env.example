# ─── API Keys (Required - pick one) ────────────────────────────

# Option A: OpenRouter (recommended — cheaper, access to multiple models)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Option B: Direct OpenAI
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your-key-here

# ─── API Keys (Optional) ───────────────────────────────────────

# Tavily API for web search (free tier at https://tavily.com)
# Without this, the Retriever Agent will still work but with limited search
TAVILY_API_KEY=your-tavily-key-here

# Anthropic API (alternative to OpenRouter for Claude models)
ANTHROPIC_API_KEY=your-anthropic-key-here
