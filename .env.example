# ─── API Keys (Required) ───────────────────────────────────────

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ─── API Keys (Optional) ───────────────────────────────────────

# Tavily API for web search (free tier at https://tavily.com)
# Without this, the Retriever Agent will still work but with limited search
TAVILY_API_KEY=your-tavily-key-here

# Anthropic API (alternative to OpenAI, if you prefer Claude)
ANTHROPIC_API_KEY=your-anthropic-key-here
