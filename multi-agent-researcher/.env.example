# Multi-Agent Deep Researcher - Environment Configuration
# Copy this to .env and fill in your values

# ========================
# AI Model Provider
# ========================
# Options: ollama, lmstudio, huggingface, mock
LLM_PROVIDER=ollama

# --- Ollama Settings ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ANALYST_MODEL=mistral
OLLAMA_CRITIC_MODEL=mistral
OLLAMA_REPORT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- LM Studio Settings ---
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_ANALYST_MODEL=microsoft/Phi-3-mini-4k-instruct
LMSTUDIO_CRITIC_MODEL=microsoft/Phi-3-mini-4k-instruct
LMSTUDIO_REPORT_MODEL=microsoft/Phi-3-mini-4k-instruct

# --- HuggingFace Settings ---
HF_TOKEN=your_hf_token_here
HF_ANALYST_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_CRITIC_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_REPORT_MODEL=meta-llama/Llama-3-8B-Instruct

# ========================
# Retrieval
# ========================
# Options: duckduckgo, searxng
RETRIEVER_PROVIDER=duckduckgo

# SearXNG (self-hosted alternative)
SEARXNG_URL=http://localhost:8080

# ========================
# Research Settings
# ========================
MAX_SOURCES_PER_QUERY=5
MAX_CLAIMS_PER_SOURCE=10
CONTRADICTION_CONFIDENCE_THRESHOLD=0.6
RESEARCH_TIMEOUT_SECONDS=300

# ========================
# API / UI
# ========================
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# ========================
# Logging
# ========================
LOG_LEVEL=INFO
